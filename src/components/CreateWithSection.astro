---
import { Image } from '@astrojs/image/components'
---

<section>
  <h2
    class="font-montserrat font-bold text-xl my-4 underline underline-offset-4 decoration-zinc-400 dark:decoration-zinc-700 decoration-4"
  >
    Created with
  </h2>
  <ul class="grid grid-cols-1 md:grid-cols-2 gap-8">
    <li class="text-center mb-4">
      <a href="https://neovim.io/">
        <Image
          class="border border-slate-300 dark:border-zinc-700 rounded-xl"
          src="/neovimio-ar21.svg"
          width={720 * 2}
          aspectRatio={2.7}
          alt="Neovim logo"
        />
        <div class="mt-3 text-xl">Neovim</div>
        <div class="opacity-70">Hyperextensible Vim-based text editor</div>
      </a>
    </li>
    <li class="text-center mb-4">
      <a href="https://astro.build/">
        <Image
          class="border border-slate-300 dark:border-zinc-700 rounded-xl"
          src="/astro-logo-light-gradient.svg"
          width={720 * 2}
          aspectRatio={2.7}
          alt="Astro logo"
        />
        <div class="mt-3 text-xl">Astro</div>
        <div class="opacity-70">
          Framework for building fast static websites
        </div>
      </a>
    </li>
  </ul>
</section>
